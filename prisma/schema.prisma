// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Quote {
  id          Int          @id @default(autoincrement())
  quote       Translation  @relation("QuoteTranslation", fields: [quoteTranslationId], references: [id])
  author      QuoteAuthor  @relation(fields: [authorId], references: [id])
  source      Translation? @relation("QuoteSourceTranslation", fields: [sourceTranslationId], references: [id])
  dailyQuotes DailyQuote[]

  quoteTranslationId  Int  @unique
  sourceTranslationId Int?
  authorId            Int
}

model QuoteAuthor {
  id                Int         @id @default(autoincrement())
  name              Translation @relation(fields: [nameTranslationId], references: [id])
  nameTranslationId Int         @unique
  quotes            Quote[]
}

model DailyQuote {
  date    DateTime @id @default(now()) @db.Date
  quote   Quote    @relation(fields: [quoteId], references: [id])
  quoteId Int
}

model ScheduleItem {
  id    Int         @id @default(autoincrement())
  date  DateTime    @db.Date
  title Translation @relation("ScheduleItemTitleTranslation", fields: [titleTranslationId], references: [id])
  venue Translation @relation("ScheduleItemVenueTranslation", fields: [venueTranslationId], references: [id])

  scheduleItemTimes   ScheduleItemTime[]
  removedScheduleItem RemovedScheduleItem?

  titleTranslationId Int
  venueTranslationId Int

  @@unique([date, venueTranslationId])
}

model ScheduleItemTime {
  id             Int          @id @default(autoincrement())
  time           DateTime     @db.Timestamptz
  designation    Translation  @relation(fields: [designationTranslationId], references: [id])
  scheduleItem   ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
  scheduleItemId Int

  designationTranslationId Int

  @@unique([time, scheduleItemId])
}

model RemovedScheduleItem {
  scheduleItemId Int          @id
  scheduleItem   ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
}

model Article {
  id              Int              @id @default(autoincrement())
  link            String           @unique
  title           Translation      @relation("ArticleTitleTranslation", fields: [titleTranslationId], references: [id])
  body            Translation      @relation("ArticleBodyTranslation", fields: [bodyTranslationId], references: [id])
  snippet         Translation      @relation("ArticleSnippetTranslation", fields: [snippetTranslationId], references: [id])
  author          ArticleAuthor    @relation(fields: [authorId], references: [id])
  image           ArticleImage     @relation(fields: [imageId], references: [id])
  dateCreated     DateTime
  dateUpdated     DateTime?
  featuredArticle FeaturedArticle?

  titleTranslationId   Int
  bodyTranslationId    Int
  snippetTranslationId Int
  authorId             Int
  imageId              Int
}

model ArticleAuthor {
  id                Int         @id @default(autoincrement())
  name              Translation @relation(fields: [nameTranslationId], references: [id])
  nameTranslationId Int         @unique
  articles          Article[]
}

model ArticleImage {
  id                   Int               @id @default(autoincrement())
  link                 String            @unique
  caption              Translation       @relation(fields: [captionTranslationId], references: [id])
  placeholder          ImagePlaceholder? @relation(fields: [placeholderId], references: [id])
  captionTranslationId Int
  placeholderId        Int?
  articles             Article[]
}

model FeaturedArticle {
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int     @id
}

model DailyGalleryImage {
  id            Int               @id @default(autoincrement())
  date          DateTime          @db.Date
  link          String
  placeholder   ImagePlaceholder? @relation(fields: [placeholderId], references: [id])
  placeholderId Int?

  @@unique([date, link])
}

model Admin {
  id    Int    @id @default(autoincrement())
  email String
  role  String

  @@unique([email, role])
}

model ImagePlaceholder {
  id                 Int                 @id @default(autoincrement())
  imageLink          String              @unique
  placeholder        String
  articleImages      ArticleImage[]
  dailyGalleryImages DailyGalleryImage[]
}

model Translation {
  id          Int     @id @default(autoincrement())
  english     String
  russian     String?
  englishHash String  @unique

  articleImageCaptions         ArticleImage[]
  articleAuthors               ArticleAuthor[]
  quoteAuthors                 QuoteAuthor[]
  quoteTranslations            Quote[]            @relation("QuoteTranslation")
  quoteSourceTranslations      Quote[]            @relation("QuoteSourceTranslation")
  scheduleItemTitles           ScheduleItem[]     @relation("ScheduleItemTitleTranslation")
  scheduleItemVenues           ScheduleItem[]     @relation("ScheduleItemVenueTranslation")
  scheduleItemTimeDesignations ScheduleItemTime[]
  articleTitleTranslations     Article[]          @relation("ArticleTitleTranslation")
  articleBodyTranslations      Article[]          @relation("ArticleBodyTranslation")
  articleSnippetTranslations   Article[]          @relation("ArticleSnippetTranslation")
}

// BetterAuth  ----------------------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
